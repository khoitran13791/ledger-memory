{
  "name": "@ledgermind/benchmark-locomo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "benchmark": "tsx src/cli.ts",
    "benchmark:smoke": "tsx src/cli.ts --smoke",
    "benchmark:canary": "tsx src/cli.ts --canary",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@ledgermind/adapters": "workspace:*",
    "@ledgermind/application": "workspace:*",
    "@ledgermind/domain": "workspace:*",
    "@ledgermind/infrastructure": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
